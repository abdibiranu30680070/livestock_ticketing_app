// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Zone {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  code   String?
  cities City[]
  users  User[]
}

model City {
  id      Int      @id @default(autoincrement())
  name    String
  zone    Zone?    @relation(fields: [zoneId], references: [id])
  zoneId  Int?
  woredas Woreda[]
  users   User[]
}

model Woreda {
  id          Int          @id @default(autoincrement())
  name        String
  city        City?        @relation(fields: [cityId], references: [id])
  cityId      Int?
  users       User[]       @relation("WorkedaUsers")
  primaryUsers User[]     @relation("PrimaryWoreda")
  tickets     Ticket[]
  collections Collection[]
}

model User {
  id                Int          @id @default(autoincrement())
  name              String
  email             String       @unique
  password          String
  role              String       @default("ticketer") // ticketer | woreda | zone | admin
  zone              Zone?        @relation(fields: [zoneId], references: [id])
  zoneId            Int?
  city              City?        @relation(fields: [cityId], references: [id])
  cityId            Int?
  woreda            Woreda?      @relation("PrimaryWoreda", fields: [woredaId], references: [id])
  woredaId          Int?
  woredas           Woreda[]     @relation("WorkedaUsers")
  tickets           Ticket[]
  collections       Collection[]
  createdAt         DateTime     @default(now())
}

model AnimalType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  taxAmount Float
  tickets   Ticket[]
}

model Ticket {
  id           Int        @id @default(autoincrement())
  reference    String     @unique
  animalType   AnimalType @relation(fields: [animalTypeId], references: [id])
  animalTypeId Int
  quantity     Float      @default(1.0)
  taxAmount    Float
  taxTaker     User       @relation(fields: [taxTakerId], references: [id])
  taxTakerId   Int
  woreda       Woreda?    @relation(fields: [woredaId], references: [id])
  woredaId     Int?
  customerName String?
  state        String     @default("draft") // draft | printed
  date         DateTime   @default(now())
}

model Collection {
  id          Int      @id @default(autoincrement())
  reference   String   @unique
  ticketer    User     @relation(fields: [ticketerId], references: [id])
  ticketerId  Int
  woreda      Woreda?  @relation(fields: [woredaId], references: [id])
  woredaId    Int?
  amount      Float
  date        DateTime @default(now())
}
